# Site institucional — Consultor Patrimonial
# Hospedagem KingHost (Apache) · site 100% estatico

Options -MultiViews -Indexes
DirectoryIndex index.html
RewriteEngine On

# 1) Redireciona /pagina.html -> /pagina (URL limpa, preserva SEO com 301)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 2) Serve internamente /pagina a partir de pagina.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Forca HTTPS (SSL Let's Encrypt do dominio ativo desde 21/07/2026)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Compressao
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# Cache de assets estaticos
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
</IfModule>

# Bloqueia acesso a diretorios/arquivos de versionamento
RedirectMatch 404 /\.git
<FilesMatch "^\.(git|gitignore|ftp-deploy-sync-state)">
  Require all denied
</FilesMatch>

# Pagina de erro cai na home
ErrorDocument 404 /index.html
